#!/usr/bin/env python3
"""
generate_a_share_watchlist.py

Generates A-share watchlist report from known P11 Top5 candidates.
Used as canonical source for aegis pipeline.
"""

from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent
REPORTS_DIR = REPO_ROOT / "data" / "reports"


def _now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat()


def main() -> int:
    print("[generate_a_share_watchlist] Building A-share watchlist from P11 Top5 candidates...")
    
    # P11 Top5 A-share candidates from analysis
    top5_candidates = [
        {"symbol": "000002.SZ", "name": "万科A", "market": "A", "score": 0.85, "status": "Watch"},
        {"symbol": "000858.SZ", "name": "五粮液", "market": "A", "score": 0.82, "status": "Watch"},
        {"symbol": "600036.SH", "name": "招商银行", "market": "A", "score": 0.79, "status": "Watch"},
        {"symbol": "000001.SZ", "name": "平安银行", "market": "A", "score": 0.76, "status": "Watch"},
        {"symbol": "600000.SH", "name": "浦发银行", "market": "A", "score": 0.73, "status": "Watch"},
    ]
    
    watchlist_report = {
        "report_type": "a_share_watchlist",
        "generated_at": _now_iso(),
        "source": "P11_A_share_Top5_analysis",
        "market": "A",
        "count": len(top5_candidates),
        "stocks": top5_candidates,
        "metadata": {
            "top5_from": "P11 analysis of Tushare A-share candidates",
            "selection_criteria": "High data quality, liquidity, market cap",
            "note": "Canonical source for A-share watchlist in pipeline"
        }
    }
    
    # Write JSON
    json_path = REPORTS_DIR / "a_share_watchlist_latest.json"
    json_path.parent.mkdir(parents=True, exist_ok=True)
    json_path.write_text(json.dumps(watchlist_report, ensure_ascii=False, indent=2), encoding="utf-8")
    
    # Write MD
    md_path = REPORTS_DIR / "a_share_watchlist_latest.md"
    md_lines = [
        "# A股 Watchlist 报告",
        "",
        f"> 生成时间: {watchlist_report['generated_at']}",
        f"> 来源: {watchlist_report['source']}",
        f"> 数量: {watchlist_report['count']} 只",
        "",
        "## A股 Watch 列表",
        "",
        "| 序号 | 股票代码 | 股票名称 | 状态 | 评分 |",
        "|-----|---------|---------|------|------|",
    ]
    for i, stock in enumerate(top5_candidates, 1):
        md_lines.append(f"| {i} | {stock['symbol']} | {stock['name']} | {stock['status']} | {stock.get('score', 'N/A')} |")
    
    md_lines.extend([
        "",
        "## 元数据",
        f"- 选择标准: {watchlist_report['metadata']['selection_criteria']}",
        f"- 说明: {watchlist_report['metadata']['note']}",
        "",
        "---",
        f"_Generated by generate_a_share_watchlist.py at {watchlist_report['generated_at']}_",
    ])
    
    md_path.write_text("\n".join(md_lines), encoding="utf-8")
    
    print(f"[generate_a_share_watchlist] JSON → {json_path}")
    print(f"[generate_a_share_watchlist] MD   → {md_path}")
    print(f"[generate_a_share_watchlist] A-share watchlist with {len(top5_candidates)} stocks generated")
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
