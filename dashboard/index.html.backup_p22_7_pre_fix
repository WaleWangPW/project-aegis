function renderRecommendations(){
  const tabsWrap = document.getElementById('rec-tabs');
  const panelsWrap = document.getElementById('rec-panels');
  const bannerWrap = document.getElementById('rec-banner');
  const cats = [
    {key:'action', label:'Action'}, {key:'ready', label:'Ready'}, {key:'watch', label:'Watch'}
  ];
  const totalRecs = cats.reduce((n,c)=> n + (DATA.recommendations[c.key]||[]).length, 0);

  if(totalRecs === 0){
    const pending = el('div','empty-pending');
    pending.style.marginBottom = 'var(--sp-3)';
    pending.innerHTML =
      '<div class="ic">'+ICONS.clock+'</div>' +
      '<div>' +
        '<p class="head">当前无新推荐</p>' +
        '<p class="body">关注风险监控状态变化，等待系统自动更新</p>' +
      '</div>';
    bannerWrap.appendChild(pending);
  }

  cats.forEach(c=>{
    const recs = DATA.recommendations[c.key] || [];
    const btn = el('button','tab-btn', c.label + '<span class="tab-count">' + recs.length + '</span>');
    btn.dataset.key = c.key;
    if(recs.length === 0) btn.disabled = true;
    tabsWrap.appendChild(btn);

    const panel = el('div','tab-panel');
    if(recs.length === 0){
      panel.innerHTML = '<div class="empty-basic">暂无 ' + c.label + ' 推荐</div>';
    }else{
      const table = el('table');
      recs.forEach(r=>{
        const tr = document.createElement('tr');
        tr.innerHTML =
          '<td><div class="ticker-cell"><span class="t">' + r.ticker + '</span><span class="m">' + r.market + '</span></div></td>' +
          '<td>' + r.reason + '</td>';
        table.appendChild(tr);
      });
      panel.appendChild(table);
    }
    panelsWrap.appendChild(panel);
  });

  if(totalRecs > 0){
    tabsWrap.addEventListener('click',e=>{
      const btn = e.target.closest('.tab-btn');
      if(!btn || btn.disabled) return;
      const key = btn.dataset.key;
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active', b.dataset.key===key));
      document.querySelectorAll('.tab-panel').forEach(p=>p.classList.toggle('active', p.dataset.key===key));
    });
  }
}

