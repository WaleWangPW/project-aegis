   ============================================================ */
async function loadFeishuDryRun(){
  const container = document.getElementById('feishu-dry-run-content');
  if(!container) return;

  try {
    const resp = await fetch('../data/reports/feishu_daily_digest_dry_run.json');
    if(!resp.ok){
      container.innerHTML = '<div class="feishu-error">⚠️ 未生成飞书 dry-run 摘要（降级显示）</div>';
      return;
    }
    const data = await resp.json();

    let html = '';

    // Status flags
    html += '<div class="feishu-status">';
    html += '<div class="feishu-status-item">dry_run: <span class="v">' + data.dry_run + '</span></div>';
    html += '<div class="feishu-status-item">sent: <span class="v ' + (data.sent ? '' : 'no') + '">' + data.sent + '</span></div>';
    html += '<div class="feishu-status-item">webhook_called: <span class="v ' + (data.webhook_called ? '' : 'no') + '">' + data.webhook_called + '</span></div>';
    html += '<div class="feishu-status-item">trading_called: <span class="v ' + (data.trading_called ? '' : 'no') + '">' + data.trading_called + '</span></div>';
    html += '</div>';

    // A-share Top 5
    if(data.a_share_top5 && data.a_share_top5.length > 0){
      html += '<div style="font-size:var(--fs-xs);color:var(--text-dim);margin-bottom:4px;">A 股 Top 5 Watch</div>';
      data.a_share_top5.forEach(function(s){
        html += '<div class="feishu-stock-row"><span class="sym">' + (s.symbol||'N/A') + ' ' + (s.name||'') + '</span><span class="stat">' + (s.status||'N/A') + ' · ' + (s.score!=null ? s.score.toFixed(2) : 'N/A') + '</span></div>';
      });
    }

    // HK sample
    if(data.hk_sample){
      var hk = data.hk_sample;
      html += '<div class="feishu-stock-row"><span class="sym">' + (hk.symbol||'00700.HK') + ' ' + (hk.name||'腾讯控股') + '</span><span class="stat">' + (hk.status||'N/A') + ' · ' + (hk.score!=null ? hk.score.toFixed(2) : 'N/A') + '</span></div>';
    }

    // Risk monitors
    if(data.risk_monitors){
      for(const [key, val] of Object.entries(data.risk_monitors)){
        html += '<div class="feishu-stock-row"><span class="sym">' + key + ' ' + (val.name||'') + '</span><span class="stat">' + (val.status||'N/A') + ' · ' + (val.score!=null ? val.score.toFixed(2) : 'N/A') + '</span></div>';
      }
    }

    // Review/Exit risks
    if(data.review_exit_risks && data.review_exit_risks.length > 0){
      html += '<div style="font-size:var(--fs-xs);color:var(--amber);margin-top:8px;margin-bottom:4px;">⚠️ Review/Exit 风险</div>';
      data.review_exit_risks.forEach(function(r){
        html += '<div class="feishu-stock-row"><span class="stat">' + r + '</span></div>';
      });
    }

    // Mobile links
    if(data.mobile_links){
      html += '<div class="feishu-links">';
      html += '📱 <a href="' + data.mobile_links.mdns + '">本地/mDNS</a>';
      html += ' · <a href="' + data.mobile_links.tailscale + '">Tailscale</a>';
      html += '</div>';
    }

    // Safety
    html += '<div class="feishu-safety">';
    html += '是否真实发送：否 · 是否调用 webhook/API：否 · 是否下单：否';
    html += '</div>';

    // Generated at
    if(data.generated_at){
      html += '<div style="margin-top:4px;font-size:10px;color:var(--text-faint);">生成时间: ' + data.generated_at + '</div>';
    }

    container.innerHTML = html;

  } catch(error){
    container.innerHTML = '<div class="feishu-error">⚠️ 飞书 dry-run JSON 解析失败（降级显示）</div>';
    console.error('Feishu dry-run load error:', error);
  }
}

/* ============================================================
   Pipeline History 模块
   ============================================================ */
async function loadPipelineHistory(){
  const container = document.getElementById('pipeline-history-content');
  if(!container) return;

  try {
    const resp = await fetch('../data/reports/aegis_pipeline_history_latest.json');
    if(!resp.ok){
      container.innerHTML = '<div style="padding:var(--sp-2);background:var(--red-soft);border-radius:var(--radius-sm);color:var(--red);font-size:var(--fs-xs);">⚠️ 未生成 pipeline 历史快照</div>';
      return;
    }
    const data = await resp.json();

    if(!data.runs || data.runs.length === 0){
      container.innerHTML = '<div style="padding:var(--sp-2);background:var(--bg-soft);border-radius:var(--radius-sm);font-size:var(--fs-xs);color:var(--text-faint);">暂无历史记录</div>';
      return;
    }

    let html = '';
    html += '<table>';
    html += '<thead><tr><th>#</th><th>Run ID</th><th>时间</th><th>Gate</th><th>Redteam</th><th>Feishu</th><th>Result</th></tr></thead>';
    html += '<tbody>';
    
    data.runs.forEach((run, idx) => {
      const gateIcon = run.gate_overall_verdict === 'PASS' ? '✅' : '❌';
      const redteamIcon = run.redteam_all_rejected ? '✅' : '❌';
      const feishuIcon = (run.feishu_dry_run === true && run.feishu_sent === false && run.feishu_webhook_called === false && run.feishu_trading_called === false) ? '✅' : '❌';
      const resultClass = run.result === 'PASS' ? 'color:var(--green)' : 'color:var(--red)';
      
      html += '<tr>';
      html += '<td style="font-size:var(--fs-2xs);color:var(--text-faint);">' + (idx + 1) + '</td>';
      html += '<td style="font-size:var(--fs-xs);font-weight:600;">' + run.run_id + '</td>';
      html += '<td style="font-size:var(--fs-2xs);color:var(--text-faint);">' + run.generated_at.substring(0, 19) + '</td>';
      html += '<td style="font-size:var(--fs-xs);">' + gateIcon + ' ' + (run.gate_overall_verdict || 'N/A') + '</td>';
      html += '<td style="font-size:var(--fs-xs);">' + redteamIcon + ' ' + (run.redteam_passed || 0) + '/' + (run.redteam_total || 0) + '</td>';
      html += '<td style="font-size:var(--fs-xs);">' + feishuIcon + '</td>';
      html += '<td style="font-size:var(--fs-xs);font-weight:600;' + resultClass + ';">' + run.result + '</td>';
      html += '</tr>';
    });
    
    html += '</tbody></table>';
    html += '<div style="margin-top:var(--sp-2);font-size:var(--fs-2xs);color:var(--text-faint);">保留数量: ' + data.retention_limit + ' · 更新: ' + data.updated_at.substring(0, 19) + '</div>';
    
    container.innerHTML = html;

  } catch(error){
    container.innerHTML = '<div style="padding:var(--sp-2);background:var(--red-soft);border-radius:var(--radius-sm);color:var(--red);font-size:var(--fs-xs);">⚠️ pipeline 历史 JSON 解析失败</div>';
    console.error('Pipeline history load error:', error);
  }
}

// Load all modules on page init
window.addEventListener('DOMContentLoaded', function(){
  loadHealthLight();
  loadFeishuDryRun();
  loadPipelineHistory();
});

</script>


