// 加载配置并获取股票数据
async function loadStockConfigAndData() {
  try {
    // 获取股票符号配置
    const symbolsResponse = await fetch('../data/reports/risk_monitor_symbols.json');
    const symbolsConfig = await symbolsResponse.json();

    // 更新移动应用通知中的股票列表
    document.getElementById('monitored-stocks-display').textContent = symbolsConfig.map(s => `${s.symbol} (${s.symbol.includes('SZ') ? 'A股' : '美股'})`).join(' · ');

    // 并行加载所有股票风险监控数据
    const promises = symbolsConfig.map(async (symbolInfo) => {
      try {
        const response = await fetch(`../data/reports/${symbolInfo.report_file}`);
        const data = await response.json();
        return data;
      } catch (error) {
        console.error(`Error loading data for ${symbolInfo.symbol}:`, error);
        return null;
      }
    });

    const stockReports = await Promise.all(promises);
    STOCK_RISK_MONITORS = stockReports.filter(report => report !== null);
    
    // 渲染多股票风险监控模块
    renderMultiStockRiskMonitor();
    
    // 更新统计信息
    renderHeroStat();
    
  } catch (error) {
    console.error('Error loading stock configuration:', error);
    // 如果配置加载失败，使用默认数据作为备用
    console.warn('Using fallback data due to configuration loading error.');
  }
}

