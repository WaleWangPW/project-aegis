</div>

<div class="wrap">

  <!-- Mobile App Notice -->
  <div class="mobile-notice">
    <h3>📱 手机使用说明</h3>
    <p><span class="icon">🔒</span> 局域网安全访问，数据每天 8 点自动刷新</p>
