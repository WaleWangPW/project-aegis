<style>
  :root{
    /* surfaces */
    --bg:#0a0e1a;
    --bg-soft:#0f1526;
    --card:#131a2e;
    --card-border:#1f2a45;

    /* text — 3 tiers only. faint is reserved for pure decoration/timestamps. */
    --text:#eef1f8;
    --text-dim:#a2acc4;
    --text-faint:#5b6478;

    /* role colors: bg-soft(12%) / solid / on-dark-text(readable on soft) */
    --accent:#3ecfd6;        --accent-soft:rgba(62,207,214,.14);
    --green:#34d399;         --green-soft:rgba(52,211,153,.14);
    --amber:#f5ab3d;         --amber-soft:rgba(245,171,61,.14);
    --blue:#5b8def;          --blue-soft:rgba(91,141,239,.14);
    --red:#f2637a;           --red-soft:rgba(242,99,122,.14);

    /* radius scale */
    --radius-sm:8px;
    --radius-md:12px;
    --radius-lg:16px;

    /* spacing scale (4px base) */
    --sp-1:4px; --sp-2:8px; --sp-3:12px; --sp-4:16px; --sp-5:24px; --sp-6:32px;

    /* type scale — 5 tiers */
    --fs-2xs:11px;  /* footer / pure metadata only */
    --fs-xs:12px;   /* labels, captions, secondary table cells */
    --fs-sm:13px;   /* body / table primary text */
    --fs-base:15px; /* emphasized data: ticker, key values */
    --fs-lg:19px;   /* section brand title */
    --fs-xl:26px;   /* hero stat number */
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;
    line-height:1.5;
    padding:0 0 60px;
    -webkit-tap-highlight-color:transparent;
  }
  .wrap{max-width:1000px;margin:0 auto;padding:0 var(--sp-3);}
  .top-band{background:linear-gradient(180deg,rgba(15,21,38,.95),var(--bg));border-bottom:1px solid var(--card-border);padding:var(--sp-4) 0 var(--sp-5);}
  .header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:var(--sp-5);}
  .brand{display:flex;align-items:center;gap:var(--sp-3);}
  .brand-mark{width:40px;height:40px;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--accent),var(--blue));display:flex;align-items:center;justify-content:center;color:#fff;}
  .brand-mark svg{width:20px;height:20px;}
  .brand h1{margin:0;font-size:var(--fs-lg);font-weight:700;color:var(--text);}
  .brand p{margin:4px 0 0;font-size:var(--fs-sm);color:var(--text-dim);}
  .header-meta{text-align:right;font-size:var(--fs-2xs);color:var(--text-faint);}
  .header-meta .date{font-size:var(--fs-sm);color:var(--text-dim);font-weight:600;margin-bottom:4px;}
  .badge-stage{display:inline-block;background:var(--accent-soft);color:var(--accent);padding:2px 8px;border-radius:100px;font-size:10px;font-weight:600;}
  .stat-row{display:flex;gap:var(--sp-4);align-items:center;margin-top:var(--sp-4);}
  .stat-hero{flex:0 0 auto;}
  .stat-hero .label{display:block;font-size:var(--fs-xs);color:var(--text-dim);margin-bottom:4px;}
  .stat-hero .value{display:block;font-size:var(--fs-xl);font-weight:700;color:var(--text);line-height:1.1;}
  .stat-hero .sub{display:block;font-size:var(--fs-2xs);color:var(--text-faint);margin-top:4px;}
  .snapshot{flex:1;display:flex;gap:var(--sp-2);flex-wrap:wrap;}
  .snapshot-item{background:var(--bg-soft);border-radius:var(--radius-sm);padding:8px 12px;font-size:var(--fs-2xs);color:var(--text-dim);border:1px solid var(--card-border);}
  .card{background:var(--card);border-radius:var(--radius-md);border:1px solid var(--card-border);padding:var(--sp-4);margin-bottom:var(--sp-4);}
  .card-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--sp-3);}
  .card-title h2{margin:0;font-size:var(--fs-base);font-weight:600;color:var(--text);display:flex;align-items:center;gap:var(--sp-2);}
  .card-title .num{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:var(--accent-soft);color:var(--accent);font-size:11px;font-weight:700;}
  .card-title .hint{font-size:var(--fs-2xs);color:var(--text-faint);}
  table{width:100%;border-collapse:collapse;font-size:var(--fs-sm);}
  th{text-align:left;padding:var(--sp-2) var(--sp-2);color:var(--text-dim);font-weight:600;font-size:var(--fs-xs);border-bottom:1px solid var(--card-border);}
  td{padding:var(--sp-2) var(--sp-2);border-bottom:1px solid rgba(255,255,255,.04);}
  tr:last-child td{border-bottom:none;}
  .ticker-cell{display:flex;flex-direction:column;gap:2px;}
  .ticker-cell .t{font-weight:700;color:var(--text);font-size:var(--fs-base);}
  .ticker-cell .m{font-size:var(--fs-2xs);color:var(--text-faint);}
  .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:100px;font-size:var(--fs-2xs);font-weight:600;white-space:nowrap;}
  .pill-hold{background:var(--green-soft);color:var(--green);}
  .pill-add{background:var(--blue-soft);color:var(--blue);}
  .pill-trim{background:var(--amber-soft);color:var(--amber);}
  .pill-exit{background:var(--red-soft);color:var(--red);}
  .pill-neutral{background:rgba(255,255,255,.08);color:var(--text-dim);}
  .pill-pending{background:var(--accent-soft);color:var(--accent);}
  .pill-pending .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);opacity:.7;}

  .cell-note{color:var(--text-dim);font-size:var(--fs-xs);line-height:1.5;}
  .cell-note .risk{color:var(--text-faint);display:block;margin-top:4px;}
  .cell-dim{color:var(--text-faint);font-size:var(--fs-xs);}

  /* recommendation tabs */
  .tabs{display:flex;gap:var(--sp-2);margin-bottom:var(--sp-3);}
  .tab-btn{
    flex:1;padding:var(--sp-2) var(--sp-1);border-radius:var(--radius-sm);border:1px solid var(--card-border);
    background:var(--bg-soft);color:var(--text-dim);font-size:var(--fs-xs);font-weight:600;
    cursor:pointer;text-align:center;transition:background .15s, color .15s, border-color .15s;
  }
  .tab-btn.active{background:var(--accent-soft);color:var(--accent);border-color:rgba(62,207,214,.35);}
  .tab-count{display:block;font-size:var(--fs-base);margin-top:2px;font-weight:700;color:var(--text-faint);}
  .tab-btn.active .tab-count{color:var(--accent);}
  .tab-panel{display:none;opacity:0;}
  .tab-panel.active{display:block;animation:fadeIn .18s ease-out forwards;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(2px);}to{opacity:1;transform:translateY(0);}}

  /* paper trading + review */
  .kv-row{display:flex;justify-content:space-between;font-size:var(--fs-xs);padding:var(--sp-2) 0;border-bottom:1px solid rgba(255,255,255,.04);}
  .kv-row:last-child{border-bottom:none;}
  .kv-row .k{color:var(--text-dim);}
  .kv-row .v{color:var(--text);font-weight:600;font-size:var(--fs-sm);}

  /* Mobile app notice */
  .mobile-notice{background:var(--bg-soft);border-radius:var(--fs-sm);padding:var(--sp-3);margin-bottom:var(--sp-3);border:1px solid var(--card-border);}
  .mobile-notice h3{margin:0 0 var(--sp-2);font-size:var(--fs-base);font-weight:600;color:var(--text);}
  .mobile-notice p{margin:0 0 var(--sp-2);font-size:var(--fs-sm);color:var(--text-dim);line-height:1.4;}
  .mobile-notice p:last-child{margin-bottom:0;}
  .mobile-notice .icon{display:inline-block;margin-right:6px;}

  /* Multi Stock Risk Monitor Module */
  .stock-monitor-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--sp-3);margin-bottom:var(--sp-3);}
  .stock-monitor-card{background:var(--bg-soft);border:1px solid var(--card-border);border-radius:var(--radius-sm);padding:var(--sp-3);}
  .stock-monitor-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--sp-2);padding-bottom:var(--sp-2);border-bottom:1px solid rgba(255,255,255,.08);}
  .stock-monitor-title{display:flex;flex-direction:column;gap:2px;}
  .stock-monitor-title .symbol{font-size:var(--fs-base);font-weight:700;color:var(--text);}
  .stock-monitor-title .meta{font-size:var(--fs-2xs);color:var(--text-faint);}
  .stock-monitor-status{display:inline-flex;align-items:center;gap:6px;padding:2px 8px;border-radius:100px;font-size:10px;font-weight:600;}
  .stock-monitor-status.eligible{background:var(--green-soft);color:var(--green);}
  .stock-monitor-status.not-eligible{background:var(--red-soft);color:var(--red);}
  .stock-metrics{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-2);margin-bottom:var(--sp-2);}
  .stock-metric{background:rgba(0,0,0,.2);padding:var(--sp-1) var(--sp-2);border-radius:var(--radius-sm);}
  .stock-metric .label{font-size:var(--fs-2xs);color:var(--text-faint);margin-bottom:2px;}
  .stock-metric .value{font-size:var(--fs-sm);font-weight:600;color:var(--text);}
  .stock-metric .value.warning{color:var(--amber);}
  .stock-metric .value.danger{color:var(--red);}
  .stock-experts{display:flex;gap:var(--sp-1);margin-bottom:var(--sp-2);}
  .stock-expert{flex:1;background:rgba(0,0,0,.2);padding:4px 8px;border-radius:var(--radius-sm);text-align:center;font-size:var(--fs-2xs);}
  .stock-expert .name{color:var(--text-faint);margin-bottom:2px;}
  .stock-expert .stance{font-weight:600;}
  .stock-expert .stance.veto{color:var(--red);}
  .stock-expert .stance.oppose{color:var(--amber);}
  .stock-expert .stance.neutral{color:var(--text-dim);}
  .stock-expert .stance.support{color:var(--green);}
  .blocking-conditions{font-size:var(--fs-2xs);color:var(--text-faint);line-height:1.3;}
  .blocking-conditions .title{color:var(--text-dim);font-weight:600;margin-bottom:4px;display:block;}
  .blocking-conditions ul{margin:0;padding:0 0 0 12px;list-style-type:square;}
  .blocking-conditions li{margin-bottom:2px;}

  footer{
    margin-top:var(--sp-6);padding-top:var(--sp-4);border-top:1px solid var(--card-border);
    font-size:var(--fs-2xs);color:var(--text-faint);
  }
  footer code{background:rgba(255,255,255,.06);padding:1px 5px;border-radius:var(--radius-sm);font-size:10px;}
</style>
</head>
<body>
<div class="top-band">
  <div class="wrap">
    <div class="header">
      <div class="brand">
        <div class="brand-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/>
            <path d="M9.5 12l1.8 1.8L14.8 10"/>
          </svg>
        </div>
        <div>
          <h1>Project Aegis 风险监控</h1>
